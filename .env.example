# =============================
# Hunter Bot Discord - Environment Variables
# Copy this file to .env and fill in your values
# =============================

# --- Discord Bot ---
DISCORD_TOKEN=your_discord_bot_token_here

# --- AI Providers ---
OPENROUTER_API_KEY=sk-or-v1-your_key_here
OPENROUTER_MODEL=liquid/lfm-2.5-1.2b-thinking:free
GEMINI_API_KEY=your_gemini_api_key_here
GROQ_API_KEY=your_groq_api_key_here

# --- Market Data APIs ---
TWELVE_DATA_API_KEY=your_twelve_data_key_here
TRADING_ECONOMICS_API_KEY=your_trading_economics_key_here
FRED_API_KEY=your_fred_api_key_here
ALPHA_VANTAGE_API_KEY=your_alpha_vantage_key_here

# --- Discord Channel IDs ---
AI_CHANNEL_ID=your_ai_channel_id
MACRO_CHANNEL_ID=your_macro_channel_id
ALERT_CHANNEL_ID=your_alert_channel_id

# --- Optional ---
VIP_ROLE_ID=your_vip_role_id

# --- Production (Railway) ---
# DATA_DIR=/mount/data
# PORT=8080
